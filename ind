window.exportSignupsCSV = async function(){
  const month = document.getElementById('exportMonth').value; // "2026-07"
  if(!month) return;
  const monthClasses = classes.filter(c => c.date.slice(0,7) === month);
  if(monthClasses.length === 0){ showToast('Geen lessen gevonden in die maand.'); return; }
  if(Object.keys(allSignups).length === 0) await loadAllSignups();
  if(members.length === 0) await loadMembers();

  let rows = [['Les','Datum','Uur','Locatie','Lid naam','Lid e-mail']];
  monthClasses.sort((a,b)=> (a.date+a.time).localeCompare(b.date+b.time)).forEach(c => {
    const ids = allSignups[c.id] || [];
    if(ids.length === 0){
      rows.push([c.name, formatDate(c.date), (c.time||'').slice(0,5), c.location||'', '', '']);
    } else {
      ids.forEach(mid => {
        const m = members.find(x=>x.id===mid);
        rows.push([c.name, formatDate(c.date), (c.time||'').slice(0,5), c.location||'', m?m.name:'?', m?m.email:'']);
      });
    }
  });
  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\r\n');
  const blob = new Blob(['\uFEFF'+csv], { type:'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `deelnemers-${month}.csv`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
};

