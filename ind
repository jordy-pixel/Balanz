function countNewPRsThisMonth(tests){
  const month = todayStr().slice(0,7);
  const byLabel = {};
  tests.forEach(t => { (byLabel[t.label] = byLabel[t.label]||[]).push(t); });
  let count = 0;
  Object.entries(byLabel).forEach(([label, arr]) => {
    const sorted = [...arr].sort((a,b)=> a.date.localeCompare(b.date));
    const direction = getDirection(label, sorted[0]?.unit);
    let best = null;
    sorted.forEach(t => {
      const v = parseFloat(t.value);
      if(isNaN(v)) return;
      const isRecord = best === null || (direction === 'hoger' ? v > best : v < best);
      if(isRecord){
        best = v;
        if(t.date.slice(0,7) === month) count++;
      }
    });
  });
  return count;
}

