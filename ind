window.handleAddClass = async function(e){
  e.preventDefault();
  const name = document.getElementById('clsName').value.trim();
  const date = document.getElementById('clsDate').value;
  const time = document.getElementById('clsTime').value;
  const location = document.getElementById('clsLocation').value.trim();
  const capacity = parseInt(document.getElementById('clsCapacity').value) || 10;
  const recurring = document.getElementById('clsRecurring').checked;
  const weeks = recurring ? (parseInt(document.getElementById('clsWeeks').value) || 1) : 1;
  if(!name || !date) return;

  const rows = [];
  const baseDate = new Date(date+'T00:00:00');
  for(let i=0;i<weeks;i++){
    const d = new Date(baseDate);
    d.setDate(d.getDate() + i*7);
    rows.push({ name, date: d.toISOString().slice(0,10), time, location, capacity });
  }
  const { error } = await sb.from('classes').insert(rows);
  if(error){ showToast('Toevoegen mislukt: '+error.message); return; }
  await loadClasses(); await loadAllSignups();
  render();
  if(weeks > 1) showToast(`${weeks} lessen aangemaakt (elke week).`);
};
