async function loadDataForTab(){
  if(!profile) return;
  const isTrainer = profile.role === 'trainer';
  if(activeMemberId){
    await loadMemberDetail(activeMemberId);
    return;
  }
  if(activeTab === 'overzicht' && isTrainer){
    await Promise.all([loadClasses(), loadMembers(), loadAllTestsSummary(), loadMonthlyLeaderboard()]);
  } else if(activeTab === 'overzicht' && !isTrainer){
    await Promise.all([loadClasses(), loadMySignups(), loadInfo(), loadMonthlyLeaderboard(), loadMyTests(), loadRecipes()]);
  } else if(activeTab === 'lessen'){
    await loadClasses();
    if(isTrainer){ await loadAllSignups(); await loadAllWaitlists(); }
    else { await loadMySignups(); await loadMyWaitlist(); }
  } else if(activeTab === 'leden'){
    await loadMembers();
  } else if(activeTab === 'testen'){
    await loadMyTests();
    await loadGoals(profile.id);
  } else if(activeTab === 'recepten'){
    await loadRecipes();
  } else if(activeTab === 'lidgeld'){
    await Promise.all([loadMembers(), loadClasses(), loadAllSignups(), loadAllPayments()]);
  } else if(activeTab === 'info'){
    await loadInfo();
  } else if(activeTab === 'profiel'){
    await loadClasses();
    if(isTrainer) await loadAllSignups(); else { await loadMySignups(); await loadPayments(profile.id); }
  }
}

