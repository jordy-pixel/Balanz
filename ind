window.handleAddTest = async function(e, memberId){
  e.preventDefault();
  const label = document.getElementById('testLabel').value.trim();
  const value = document.getElementById('testValue').value.trim();
  const unit = document.getElementById('testUnit').value.trim();
  const note = document.getElementById('testNote').value.trim();
  const date = document.getElementById('testDate').value || todayStr();
  if(!label || !value) return;

  const previousForLabel = viewedMemberTests.filter(t => t.label === label);
  const previousValues = previousForLabel.map(t=>parseFloat(t.value)).filter(v=>!isNaN(v));
  const direction = getDirection(label, unit);
  const newVal = parseFloat(value);
  const isPR = previousValues.length > 0 && !isNaN(newVal) &&
    (direction === 'hoger' ? newVal > Math.max(...previousValues) : newVal < Math.min(...previousValues));

  const { error } = await sb.from('tests').insert({ member_id: memberId, label, value, unit, note, date });
  if(error){ showToast('Toevoegen mislukt: '+error.message); return; }
  await loadMemberDetail(memberId);
  render();
  if(isPR) showToast(`🏆 Persoonlijk record voor ${label}!`);
};
