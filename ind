function buildLineChart(sorted){
  const pts = sorted.map(t => ({ date: t.date, v: parseFloat(t.value) })).filter(p => !isNaN(p.v));
  if(pts.length < 2) return '';
  const width = 320, height = 130, padX = 14, padY = 18;
  let minV = Math.min(...pts.map(p=>p.v));
  let maxV = Math.max(...pts.map(p=>p.v));
  if(minV === maxV){ minV -= 1; maxV += 1; }
  const xStep = (width - padX*2) / (pts.length - 1);
  const coords = pts.map((p,i) => {
    const x = padX + i*xStep;
    const y = height - padY - ((p.v - minV)/(maxV - minV)) * (height - padY*2);
    return { x, y, v: p.v, date: p.date };
  });
  const pathD = coords.map((c,i) => (i===0?'M':'L') + c.x.toFixed(1) + ',' + c.y.toFixed(1)).join(' ');
  const areaD = pathD + ` L${coords[coords.length-1].x.toFixed(1)},${height-padY} L${coords[0].x.toFixed(1)},${height-padY} Z`;
  const circles = coords.map(c => `<circle cx="${c.x.toFixed(1)}" cy="${c.y.toFixed(1)}" r="3.5" fill="var(--amber)" stroke="var(--ink-2)" stroke-width="1.5"><title>${escapeHtml(formatDate(c.date))}: ${escapeHtml(String(c.v))}</title></circle>`).join('');
  return `
    <svg viewBox="0 0 ${width} ${height+16}" style="width:100%; height:auto; display:block; margin-top:10px;">
      <line x1="${padX}" y1="${height-padY}" x2="${width-padX}" y2="${height-padY}" stroke="var(--line)" stroke-width="1"/>
      <path d="${areaD}" fill="rgba(214,213,62,0.12)" stroke="none"/>
      <path d="${pathD}" fill="none" stroke="var(--amber)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
      ${circles}
      <text x="${padX}" y="${height+12}" fill="var(--muted)" font-size="10" font-family="IBM Plex Mono, monospace">${escapeHtml(formatDate(coords[0].date))}</text>
      <text x="${width-padX}" y="${height+12}" fill="var(--muted)" font-size="10" font-family="IBM Plex Mono, monospace" text-anchor="end">${escapeHtml(formatDate(coords[coords.length-1].date))}</text>
    </svg>`;
}

function getDirection(label, unit){
  const g = goals[label];
  if(g) return g.direction;
  const u = (unit||'').toLowerCase();
  if(u.includes('min') || u.includes('sec') || u.includes('u')) return 'lager';
  return 'hoger';
}

function renderScoreboard(label, arr, memberId, trainerView){
  const sorted = [...arr].sort((a,b)=> a.date.localeCompare(b.date));
  const latest = sorted[sorted.length-1];
  const prev = sorted[sorted.length-2];
  let deltaHtml = '';
  if(prev){
    const diff = parseFloat(latest.value) - parseFloat(prev.value);
    if(!isNaN(diff)) deltaHtml = `<span class="delta ${diff<0?'neg':''}">${diff>0?'+':''}${diff.toFixed(1)}</span>`;
  }
  const chart = buildLineChart(sorted);
  const direction = getDirection(label, latest.unit);
  const numericValues = sorted.map(t=>parseFloat(t.value)).filter(v=>!isNaN(v));
  const bestValue = numericValues.length ? (direction === 'hoger' ? Math.max(...numericValues) : Math.min(...numericValues)) : null;
  const latestIsPR = bestValue !== null && parseFloat(latest.value) === bestValue && sorted.length > 1;
  const goal = goals[label];
  let goalHtml = '';
  if(goal){
    const lv = parseFloat(latest.value);
    const tv = parseFloat(goal.target_value);
    let pct = 0;
    if(!isNaN(lv) && !isNaN(tv)){
      if(goal.direction === 'hoger'){
        const startEstimate = numericValues.length ? Math.min(...numericValues) : lv;
        pct = tv === startEstimate ? 100 : Math.max(0, Math.min(100, ((lv - startEstimate) / (tv - startEstimate)) * 100));
      } else {
        const startEstimate = numericValues.length ? Math.max(...numericValues) : lv;
        pct = startEstimate === tv ? 100 : Math.max(0, Math.min(100, ((startEstimate - lv) / (startEstimate - tv)) * 100));
      }
    }
    const reached = (goal.direction === 'hoger' && lv >= tv) || (goal.direction === 'lager' && lv <= tv);
    goalHtml = `
      <div style="margin-top:12px; padding-top:12px; border-top:1px solid var(--line);">
        <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--muted); margin-bottom:5px;">
          <span>Doel: ${escapeHtml(goal.target_value)} ${escapeHtml(latest.unit||'')}</span>
          <span>${reached ? '🎯 Doel bereikt!' : Math.round(pct)+'%'}</span>
        </div>
        <div style="background:var(--ink-2); border-radius:6px; height:8px; overflow:hidden;">
          <div style="background:${reached?'var(--teal)':'var(--amber)'}; height:100%; width:${Math.round(pct)}%; transition:width .3s ease;"></div>
        </div>
        ${trainerView || !trainerView ? `<button class="btn ghost small" style="margin-top:8px;" onclick="removeGoal('${memberId}','${escapeHtml(label)}')">Doel verwijderen</button>` : ''}
      </div>`;
  } else {
    goalHtml = `
      <div style="margin-top:12px; padding-top:12px; border-top:1px solid var(--line);">
        <button class="btn ghost small" onclick="showGoalForm('${memberId}','${escapeHtml(label).replace(/'/g,"\\'")}')">+ Doel instellen</button>
        <div id="goalForm-${memberId}-${label.replace(/[^a-zA-Z0-9]/g,'')}"></div>
      </div>`;
  }

  return `
    <div class="scoreboard">
      <div class="label">${escapeHtml(label)} ${latestIsPR ? `<span style="color:var(--amber); font-size:11.5px; font-weight:700;">🏆 PR</span>` : ''}</div>
      <div class="big">
        <span class="val">${escapeHtml(latest.value)}</span>
        <span class="unit">${escapeHtml(latest.unit||'')}</span>
        ${deltaHtml}
      </div>
      <div class="date">Laatst gemeten op ${formatDate(latest.date)}${latest.note? ' · '+escapeHtml(latest.note):''}</div>
      ${chart || (sorted.length===1 ? `<div class="hint">Nog maar 1 meting — de grafiek verschijnt vanaf de tweede meting.</div>` : '')}
      ${sorted.length>1 ? `
      <table style="margin-top:12px;">
        <tr><th>Datum</th><th>Waarde</th>${trainerView?'<th></th>':''}</tr>
        ${sorted.slice().reverse().map(t=>`<tr><td>${formatDate(t.date)}</td><td class="mono">${escapeHtml(t.value)} ${escapeHtml(t.unit||'')}</td>${trainerView?`<td style="text-align:right;"><button class="btn ghost small" onclick="deleteTest('${memberId}','${t.id}')">Verwijder</button></td>`:''}</tr>`).join('')}
      </table>` : ''}
      ${goalHtml}
    </div>`;
}

