function escapeHtml(str){
  return String(str ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function formatDate(d){
  const dt = new Date(d + (String(d).length===10 ? 'T00:00:00' : ''));
  return dt.toLocaleDateString('nl-BE', {day:'2-digit', month:'short', year:'numeric'});
}
function weekdayName(dateStr){
  if(!dateStr) return '';
  const d = new Date(dateStr+'T00:00:00');
  const names = ['Zondag','Maandag','Dinsdag','Woensdag','Donderdag','Vrijdag','Zaterdag'];
  return names[d.getDay()];
}
function todayStr(){ return new Date().toISOString().slice(0,10); }

function isoWeekKey(dateStr){
  const d = new Date(dateStr+'T00:00:00');
  d.setDate(d.getDate() + 4 - (d.getDay()||7));
  const yearStart = new Date(d.getFullYear(),0,1);
  const week = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
  return d.getFullYear() + '-W' + week;
}

// Aantal opeenvolgende weken (tot vandaag) met minstens 1 les bijgewoond
function computeStreak(memberId, allClasses, signupsByClass){
  const today = todayStr();
  const attendedWeeks = new Set();
  Object.entries(signupsByClass).forEach(([classId, memberIds]) => {
    if(!memberIds.includes(memberId)) return;
    const cls = allClasses.find(c => c.id === classId);
    if(!cls || cls.date >= today) return; // enkel voorbije lessen tellen als 'bijgewoond'
    attendedWeeks.add(isoWeekKey(cls.date));
  });
  let streak = 0;
  let cursor = new Date();
  while(true){
    const key = isoWeekKey(cursor.toISOString().slice(0,10));
    if(attendedWeeks.has(key)){ streak++; cursor.setDate(cursor.getDate()-7); }
    else break;
  }
  return streak;
}

function computeMonthlyLeaderboard(allClasses, signupsByClass, allMembers){
  const month = todayStr().slice(0,7);
  const counts = {};
  Object.entries(signupsByClass).forEach(([classId, memberIds]) => {
    const cls = allClasses.find(c => c.id === classId);
    if(!cls || cls.date.slice(0,7) !== month || cls.date >= todayStr()) return;
    memberIds.forEach(mid => { counts[mid] = (counts[mid]||0) + 1; });
  });
  return Object.entries(counts)
    .map(([mid, cnt]) => ({ member: allMembers.find(m=>m.id===mid), cnt }))
    .filter(r => r.member)
    .sort((a,b) => b.cnt - a.cnt)
    .slice(0,5);
}

function upcomingBirthdays(allMembers, daysAhead){
  const today = new Date();
  today.setHours(0,0,0,0);
  return allMembers
    .filter(m => m.birth_date)
    .map(m => {
      const bd = new Date(m.birth_date+'T00:00:00');
      let next = new Date(today.getFullYear(), bd.getMonth(), bd.getDate());
      if(next < today) next = new Date(today.getFullYear()+1, bd.getMonth(), bd.getDate());
      const diffDays = Math.round((next - today) / 86400000);
      return { member: m, next, diffDays };
    })
    .filter(r => r.diffDays <= daysAhead)
    .sort((a,b) => a.diffDays - b.diffDays);
}

function showToast(msg){
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(()=> t.remove(), 2600);
}

/* ---------------- INIT & AUTH ---------------- */

function setupPWA(){
  const manifest = {
    name: 'Balanz', short_name: 'Balanz',
    start_url: '.', scope: '.', display: 'standalone',
    background_color: '#1C1712', theme_color: '#1C1712',
    icons: [{ src: LOGO_B64, sizes: '260x260', type: 'image/png', purpose: 'any' }]
  };
  const blob = new Blob([JSON.stringify(manifest)], { type: 'application/manifest+json' });
  const manifestLink = document.createElement('link');
  manifestLink.rel = 'manifest';
  manifestLink.href = URL.createObjectURL(blob);
  document.head.appendChild(manifestLink);

  const touchIcon = document.createElement('link');
  touchIcon.rel = 'apple-touch-icon';
  touchIcon.href = LOGO_B64;
  document.head.appendChild(touchIcon);

  const themeColor = document.createElement('meta');
  themeColor.name = 'theme-color';
  themeColor.content = '#1C1712';
  document.head.appendChild(themeColor);

  const appleCapable = document.createElement('meta');
  appleCapable.name = 'apple-mobile-web-app-capable';
  appleCapable.content = 'yes';
  document.head.appendChild(appleCapable);

  const appleTitle = document.createElement('meta');
  appleTitle.name = 'apple-mobile-web-app-title';
  appleTitle.content = 'Balanz';
  document.head.appendChild(appleTitle);
}

async function init(){
  setupPWA();
  const refParam = new URLSearchParams(window.location.search).get('ref');
  if(refParam) pendingReferralCode = refParam;
  // Vangnet: detecteer een wachtwoord-herstellink rechtstreeks in de URL,
  // want het 'PASSWORD_RECOVERY' event kan gemist worden als het te vroeg vuurt.
  const urlHasRecovery = (window.location.hash + window.location.search).includes('type=recovery');
  if(urlHasRecovery){
    authStage = 'reset-password';
  }

  sb.auth.onAuthStateChange((event, newSession) => {
    session = newSession;
    if(event === 'PASSWORD_RECOVERY'){
      authStage = 'reset-password';
      loading = false;
      render();
      return;
    }
    if(authStage === 'reset-password') return; // niet overschrijven tijdens het herstelproces
    handleAuthChange();
  });

  const { data } = await sb.auth.getSession();
  session = data.session;
  await fetchSettings();
  await handleAuthChange();
}

async function handleAuthChange(){
  loading = false;
  if(authStage === 'reset-password') { render(); return; }
  if(!session){
    profile = null;
    render();
    return;
  }
  const { data: prof, error } = await sb.from('profiles').select('*').eq('id', session.user.id).maybeSingle();
  if(error){ console.error(error); }
  if(!prof){
    authStage = 'onboarding';
    profile = null;
    render();
    return;
  }
  profile = prof;
  authStage = 'idle';
  if(!activeTab) activeTab = profile.role === 'trainer' ? 'overzicht' : 'lessen';
  await loadDataForTab();
  render();
}

