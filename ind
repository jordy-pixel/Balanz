  const bySelf = {};
  mySignups.forEach(cid => bySelf[cid] = [profile.id]);
  const streak = !isTrainer ? computeStreak(profile.id, classes, bySelf) : 0;

  const myAttended = !isTrainer ? classes.filter(c => c.date < todayStr() && mySignups.includes(c.id)).length : 0;
  const myTotalPaid = !isTrainer ? payments.reduce((s,p)=> s + (p.sessions_included||0), 0) : 0;
  const myBalance = myTotalPaid > 0 ? myTotalPaid - myAttended : null;

  return `
    <h2 class="section-title">Mijn profiel</h2>
    <div class="section-sub">Beheer je naam, geboortedatum, e-mailadres en wachtwoord.${streak > 0 ? ` · 🔥 ${streak} ${streak===1?'week':'weken'} op rij actief` : ''}</div>

    ${!isTrainer ? `
    <div class="card" style="max-width:480px; margin-bottom:20px;">
      <h3 style="margin-bottom:14px;">Mijn beurten &amp; lidgeld</h3>
      <div class="grid cols-3" style="margin-bottom:14px;">
        <div class="stat-card"><div class="num">${myAttended}</div><div class="lbl">Opgenomen</div></div>
        <div class="stat-card"><div class="num">${myTotalPaid || '–'}</div><div class="lbl">Betaald</div></div>
        <div class="stat-card"><div class="num" style="color:${myBalance!==null && myBalance<0 ? 'var(--red)' : 'var(--amber)'};">${myBalance!==null ? myBalance : '–'}</div><div class="lbl">Saldo</div></div>
      </div>
      ${payments.length === 0 ? `<div class="hint" style="margin-top:0;">Nog geen betalingen geregistreerd door je trainer.</div>` : `
      <table>
        <tr><th>Datum</th><th>Bedrag</th><th>Beurten</th></tr>
        ${payments.map(p => `<tr><td>${formatDate(p.date)}</td><td class="mono">${p.amount!=null?'€'+parseFloat(p.amount).toFixed(2):'–'}</td><td class="mono">${p.sessions_included ?? '–'}</td></tr>`).join('')}
      </table>`}
    </div>` : ''}

    <div class="card" style="max-width:480px; margin-bottom:20px;">
      <h3 style="margin-bottom:14px;">Nodig een vriend uit</h3>
      ${profile.referral_code ? `
      <div class="hint" style="margin-top:0; margin-bottom:10px;">Deel deze link — wie zich hiermee aanmeldt, koppelen we automatisch aan jouw naam.</div>
      <div class="inline-form">
        <div class="field" style="flex:1; min-width:200px;"><input id="referralLinkField" type="text" readonly value="${window.location.origin}${window.location.pathname}?ref=${escapeHtml(profile.referral_code)}"></div>
        <button class="btn ghost small" onclick="copyReferralLink()">Kopieer link</button>
      </div>` : `
      <button class="btn ghost small" onclick="ensureReferralCode()">Genereer mijn uitnodigingslink</button>`}
    </div>

    <div class="card" style="max-width:480px; margin-bottom:20px;">
      <h3 style="margin-bottom:14px;">Naam &amp; geboortedatum</h3>
      <form onsubmit="handleUpdateName(event)">
        <div class="field"><label>Naam</label><input id="profName" type="text" value="${escapeHtml(profile.name)}" required></div>
        <div class="field"><label>Geboortedatum (optioneel)</label><input id="profBirthdate" type="date" value="${profile.birth_date || ''}"></div>
        <button class="btn" type="submit">Opslaan</button>
      </form>
    </div>

    <div class="card" style="max-width:480px; margin-bottom:20px;">
      <h3 style="margin-bottom:14px;">E-mailadres</h3>
      <form onsubmit="handleUpdateEmail(event)">
        <div class="field"><input id="profEmail" type="email" value="${escapeHtml(session.user.email)}" required></div>
        <div class="hint" style="margin-top:-6px; margin-bottom:12px;">Bij wijziging ontvang je een bevestigingsmail op het nieuwe adres.</div>
        <button class="btn ghost" type="submit">E-mailadres wijzigen</button>
      </form>
    </div>

    <div class="card" style="max-width:480px;">
      <h3 style="margin-bottom:14px;">Wachtwoord wijzigen</h3>
      <form onsubmit="handleUpdatePasswordDirect(event)">
        <div class="field"><label>Nieuw wachtwoord</label><input id="profPassword" type="password" minlength="6" required></div>
        <div class="field"><label>Herhaal wachtwoord</label><input id="profPassword2" type="password" minlength="6" required></div>
        <button class="btn ghost" type="submit">Wachtwoord wijzigen</button>
      </form>
    </div>
  `;
}

window.copyReferralLink = function(){
  const field = document.getElementById('referralLinkField');
  field.select();
  navigator.clipboard?.writeText(field.value).then(()=> showToast('Link gekopieerd!')).catch(()=> showToast('Kopiëren mislukt — selecteer en kopieer manueel.'));
};

window.ensureReferralCode = async function(){
  const code = genReferralCode();
  const { data, error } = await sb.from('profiles').update({ referral_code: code }).eq('id', profile.id).select().single();
  if(error){ showToast('Aanmaken link mislukt: ' + error.message); return; }
  profile = data;
  render();
};

window.handleUpdateName = async function(e){
  e.preventDefault();
  const name = document.getElementById('profName').value.trim();
  const birth_date = document.getElementById('profBirthdate').value || null;
  if(!name) return;
  const { data, error } = await sb.from('profiles').update({ name, birth_date }).eq('id', profile.id).select().single();
  if(error){ showToast('Opslaan mislukt: ' + error.message); return; }
  profile = data;
  render();
  showToast('Opgeslagen.');
};

window.handleUpdateEmail = async function(e){
  e.preventDefault();
  const email = document.getElementById('profEmail').value.trim();
  if(!email || email === session.user.email) return;
  const { error } = await sb.auth.updateUser({ email });
  if(error){ showToast('Wijzigen mislukt: ' + error.message); return; }
  showToast('Bevestigingsmail verstuurd naar het nieuwe adres.');
};

window.handleUpdatePasswordDirect = async function(e){
  e.preventDefault();
  const password = document.getElementById('profPassword').value;
  const password2 = document.getElementById('profPassword2').value;
  if(password.length < 6){ showToast('Wachtwoord moet minstens 6 tekens bevatten.'); return; }
  if(password !== password2){ showToast('De twee wachtwoorden komen niet overeen.'); return; }
  const { error } = await sb.auth.updateUser({ password });
  if(error){ showToast('Wijzigen mislukt: ' + error.message); return; }
  document.getElementById('profPassword').value = '';
  document.getElementById('profPassword2').value = '';
  showToast('Wachtwoord succesvol gewijzigd.');
};

function renderSettings(){
  return `
    <h2 class="section-title">Instellingen</h2>
    <div class="section-sub">Pas de naam en tagline van je studio aan.</div>
    <div class="card" style="max-width:480px;">
      <form onsubmit="handleSettingsSave(event)">
        <div class="field"><label>Studionaam</label><input id="setStudioName" type="text" value="${escapeHtml(settings.studio_name)}" required></div>
        <div class="field"><label>Tagline (op inlogscherm)</label><input id="setTagline" type="text" value="${escapeHtml(settings.tagline||'')}" placeholder="Bijv. Sterker worden, samen."></div>
        <button class="btn" type="submit">Opslaan</button>
      </form>
    </div>
  `;
}

init();
</script>
</body>
</html>
